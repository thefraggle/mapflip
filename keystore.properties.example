# Google Play Release Keystore Configuration
# Kopiere diese Datei zu "keystore.properties" und trage deine echten Keys ein.
# Die Datei "keystore.properties" ist in .gitignore eingetragen und wird nicht hochgeladen.

storeFile=mapflip-release.jks
storePassword=dein_keystore_passwort
keyAlias=mapflip-key
keyPassword=dein_schluessel_passwort
